# PostgreSQL connection string used by Prisma.
# Local: postgresql://postgres:postgres@localhost:5432/crm_ventas?schema=public
# Staging/production: Neon pooled or direct connection URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_ventas?schema=public"

# NextAuth public URL and signing secret.
# Local: http://localhost:3000
# Staging/production: Vercel URL or custom domain.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Redis connection for BullMQ jobs.
# Local: redis://localhost:6379
# Staging/production: Upstash Redis URL. rediss:// is supported.
REDIS_URL="redis://localhost:6379"

# SendGrid global fallback credentials.
SENDGRID_API_KEY=""
SENDGRID_INBOUND_DOMAIN="demo.local"

# Per-agency SendGrid credentials use the agency slug uppercased and normalized, for example:
# SENDGRID_API_KEY_DEMO_AGENCY=""

# Twilio global fallback credentials.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
TWILIO_WHATSAPP_NUMBER=""
TWILIO_VALIDATE_SIGNATURE="true"

# Per-agency Twilio credentials use the agency slug uppercased and normalized, for example:
# TWILIO_ACCOUNT_SID_DEMO_AGENCY=""
# TWILIO_AUTH_TOKEN_DEMO_AGENCY=""
# TWILIO_PHONE_NUMBER_DEMO_AGENCY=""
# TWILIO_WHATSAPP_NUMBER_DEMO_AGENCY=""

# 32-byte encryption key for stored channel credentials. Use base64 or a 64-char hex key.
# Use a strong generated value and keep it identical across Vercel and worker services.
CHANNEL_CONFIG_ENCRYPTION_KEY=""

# OpenAI lead qualification. If OPENAI_API_KEY is empty, the app uses a local heuristic fallback.
OPENAI_API_KEY=""
OPENAI_LEAD_MODEL="gpt-4o-mini"
